{
  "name": "@codyswann/api-creator",
  "version": "0.1.3",
  "description": "Reverse-engineer any web API into a typed CLI by recording real browser traffic",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "api-creator": "./bin/api-creator.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodySwannGT/api-creator.git"
  },
  "homepage": "https://github.com/CodySwannGT/api-creator#readme",
  "bugs": {
    "url": "https://github.com/CodySwannGT/api-creator/issues"
  },
  "author": "Cody Swann",
  "license": "MIT",
  "keywords": [
    "api",
    "cli",
    "har",
    "typescript",
    "code-generator",
    "reverse-engineering",
    "playwright"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/node": "^25.5.0",
    "husky": "^8.0.0",
    "standard-version": "^9.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
