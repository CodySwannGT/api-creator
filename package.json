{
  "scripts": {
    "build": "tsup",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "postinstall": "[ -n \"$CI\" ] || node node_modules/@codyswann/lisa/dist/index.js --yes --skip-git-check . 2>/dev/null || true",
    "test": "vitest run",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "$npm_execpath run build",
    "prepare": "node -e \"if (process.env.INIT_CWD && process.env.INIT_CWD.includes('.serverless')) { process.exit(0); }\" && husky install || true",
    "lint": "eslint . --quiet",
    "format:check": "prettier --check .",
    "format": "prettier --check . --write",
    "test:unit": "vitest run --exclude='**/integration/**'",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "lint:fix": "eslint . --fix",
    "lint:slow": "eslint . --config eslint.slow.config.ts --quiet",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "sg:scan": "ast-grep scan"
  },
  "engines": {
    "npm": "please-use-bun",
    "yarn": "please-use-bun",
    "pnpm": "please-use-bun",
    "bun": "1.3.8",
    "node": ">=18"
  },
  "name": "@codyswann/api-creator",
  "version": "0.1.15",
  "description": "Reverse-engineer any web API into a typed CLI by recording real browser traffic",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "api-creator": "./bin/api-creator.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodySwannGT/api-creator.git"
  },
  "homepage": "https://github.com/CodySwannGT/api-creator#readme",
  "bugs": {
    "url": "https://github.com/CodySwannGT/api-creator/issues"
  },
  "author": "Cody Swann",
  "license": "MIT",
  "keywords": [
    "api",
    "cli",
    "har",
    "typescript",
    "code-generator",
    "reverse-engineering",
    "playwright"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "playwright": "^1.58.2",
    "vite": "^8.0.7"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.42.0",
    "@codyswann/lisa": "^2.1.0",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-sonarjs": "^4.0.3",
    "husky": "^8.0.0",
    "knip": "^5.88.1",
    "prettier": "^3.8.1",
    "standard-version": "^9.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  },
  "resolutions": {
    "@isaacs/brace-expansion": "^5.0.1",
    "axios": ">=1.15.0",
    "picomatch": ">=4.0.4",
    "minimatch": ">=10.2.1",
    "yaml": ">=2.8.3",
    "smol-toml": ">=1.6.1",
    "handlebars": ">=4.7.9"
  },
  "overrides": {
    "@isaacs/brace-expansion": "^5.0.1",
    "axios": ">=1.15.0",
    "picomatch": ">=4.0.4",
    "minimatch": ">=10.2.1",
    "yaml": ">=2.8.3",
    "smol-toml": ">=1.6.1",
    "vite": ">=8.0.5",
    "handlebars": ">=4.7.9",
    "eslint-plugin-sonarjs": "^4.0.3"
  },
  "trustedDependencies": [
    "@ast-grep/cli",
    "@codyswann/lisa",
    "@sentry/cli"
  ]
}
